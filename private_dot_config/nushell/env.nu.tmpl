{{- template "nu-common-env.nu" . -}}

starship init nu | save -f ~/.cache/starship/init.nu
$env.EDITOR = "lvim"
$env.hostip = (cat /etc/resolv.conf |grep -oP '(?<=nameserver\ ).*')
$env.TERM = "tmux-256color"
$env.DISPLAY = $"($env.hostip):0"
$env.GPG_TTY = (tty)
