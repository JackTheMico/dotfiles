{{ if ne .chezmoi.os "windows" }}
[".local/bin/cht.sh"]
    type = "file"
    url = "https://cht.sh/:cht.sh"
    refreshPeriod = "168h"
    executable = true
[".local/bin/himalaya"]
    type = "archive-file"
    url = "https://github.com/soywod/himalaya/releases/latest/download/himalaya-linux.tgz"
    path = "himalaya"
[".tmux"]
    type = "git-repo"
    url = "https://github.com/gpakosz/.tmux.git"
    refreshPeriod = "168h"
{{ end }}
